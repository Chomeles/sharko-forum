# Copy to .env and fill in. The installer generates the secrets for you.

# ── Required ──
# Long random string. Generate: python3 -c "import secrets;print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=
# Comma-separated hostnames the forum is served on (no scheme).
ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated origins for CSRF (WITH scheme). Set to your public URL in prod.
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# ── Database (Postgres) ──
POSTGRES_DB=forum
POSTGRES_USER=forum
POSTGRES_PASSWORD=
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Optional ──
# 1 = debug mode. NEVER enable in production.
DJANGO_DEBUG=
# IANA timezone, e.g. Europe/Berlin. Default UTC.
TIME_ZONE=UTC
# Outgoing mail for password resets. Leave EMAIL_HOST blank to print reset links
# to the container log (fine for testing); set a real SMTP host for production.
EMAIL_HOST=
EMAIL_PORT=25
DEFAULT_FROM_EMAIL=forum@localhost

# ── Sub-path hosting (leave blank to serve at the domain root) ──
# Set these three together only if a proxy serves the app under a prefix AND strips it.
# FORCE_SCRIPT_NAME=/forum
# DJANGO_STATIC_URL=/forum/static/
# SESSION_COOKIE_PATH=/forum
# CSRF_COOKIE_PATH=/forum
